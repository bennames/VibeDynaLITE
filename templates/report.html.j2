<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KevlarGrid Simulation Report</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; color: #333; }
        h1 { color: #1a1a2e; border-bottom: 2px solid #16213e; padding-bottom: 10px; }
        h2 { color: #16213e; }
        table { border-collapse: collapse; width: 100%; margin: 15px 0; }
        th, td { border: 1px solid #ddd; padding: 8px 12px; text-align: left; }
        th { background-color: #16213e; color: white; }
        tr:nth-child(even) { background-color: #f9f9f9; }
        .pass { color: #27ae60; font-weight: bold; font-size: 1.5em; }
        .fail { color: #e74c3c; font-weight: bold; font-size: 1.5em; }
        .marginal { color: #f39c12; font-weight: bold; font-size: 1.5em; }
        .metric-card { display: inline-block; background: #f8f9fa; border-radius: 8px; padding: 15px 25px; margin: 5px; text-align: center; }
        .metric-value { font-size: 1.8em; font-weight: bold; color: #16213e; }
        .metric-label { font-size: 0.9em; color: #666; }
        .plot-container { margin: 20px 0; text-align: center; }
        .plot-container img { max-width: 100%; border: 1px solid #eee; border-radius: 4px; }
        .timestamp { color: #999; font-size: 0.85em; }
    </style>
</head>
<body>
    <h1>KevlarGrid Simulation Report</h1>
    <p class=\"timestamp\">Generated: {{ timestamp }}</p>

    <h2>Result</h2>
    <p class=\"{{ result_class }}\">{{ result_text }}</p>

    <h2>Key Metrics</h2>
    <div>
        {% for metric in metrics %}
        <div class=\"metric-card\">
            <div class=\"metric-value\">{{ metric.value }}</div>
            <div class=\"metric-label\">{{ metric.label }}</div>
        </div>
        {% endfor %}
    </div>

    <h2>Configuration</h2>
    <table>
        <tr><th>Parameter</th><th>Value</th></tr>
        {% for key, value in config.items() %}
        <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
        {% endfor %}
    </table>

    <h2>Strain vs. Time</h2>
    <div class=\"plot-container\">
        {% if strain_plot_path %}
        <img src=\"{{ strain_plot_path }}\" alt=\"Strain vs Time\">
        {% else %}
        <p><em>Plot not available</em></p>
        {% endif %}
    </div>

    <h2>Energy Balance</h2>
    <div class=\"plot-container\">
        {% if energy_plot_path %}
        <img src=\"{{ energy_plot_path }}\" alt=\"Energy Balance\">
        {% else %}
        <p><em>Plot not available</em></p>
        {% endif %}
    </div>

    {% if failure_map_path %}
    <h2>Failure Map</h2>
    <div class=\"plot-container\">
        <img src=\"{{ failure_map_path }}\" alt=\"Failure Map\">
    </div>
    {% endif %}

    <footer>
        <p class=\"timestamp\">KevlarGrid Explicit Solver v{{ version }}</p>
    </footer>
</body>
</html>
